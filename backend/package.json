{
  "name": "scars-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "UV_THREADPOOL_SIZE=2 node --max-old-space-size=256 server/index.js",
    "dev": "nodemon --watch server server/index.js",
    "postinstall": "prisma generate",
    "build:frontend": "npm install --prefix ../frontend && npm run build --prefix ../frontend",
    "deploy": "prisma generate && prisma db push && node prisma/seed.js && npm run build:frontend",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.4",
    "prisma": "^7.6.0",
    "socket.io": "^4.8.3",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
