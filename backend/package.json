{
  "name": "scars-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon --watch server server/index.js",
    "postinstall": "prisma generate",
    "build:frontend": "npm install --prefix ../frontend && npm run build --prefix ../frontend",
    "deploy": "prisma generate && prisma db push && node prisma/seed.js && npm run build:frontend",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.17.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
