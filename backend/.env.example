# ── UV SCARS — Environment Variables Template ──────────────────────────────────
#
# LOCAL DEVELOPMENT
#   Copy this file to .env and fill in your local MySQL credentials.
#   1. cd backend  && npm run dev   (Express on :3001)
#   2. cd frontend && npm run dev   (Vite on :5173)
#
# HOSTINGER PRODUCTION
#   Do NOT place a .env file on the server.
#   Set all variables in hPanel → Node.js → Environment Variables.
#
# ──────────────────────────────────────────────────────────────────────────────

# MySQL connection string
# Local (XAMPP default):  mysql://root:@localhost:3306/scars_db
# Hostinger:              mysql://u856082912_scars:PASSWORD@localhost:3306/u856082912_scars_db
DATABASE_URL="mysql://root:@localhost:3306/scars_db"

# JWT signing secret
# Local:      any string
# Production: run  openssl rand -hex 32  and paste the result
JWT_SECRET="change-me"

# Express server port
PORT=3001

# "development" → open CORS, dev-friendly errors, no static serving (Vite handles it)
# "production"  → restricted CORS to FRONTEND_URL, Express serves built public/ folder
NODE_ENV=development

# Public URL — used for CORS restriction in production only
# Local:      http://localhost:5173
# Hostinger:  https://uv-scars.com
FRONTEND_URL=http://localhost:5173

# Face++ API for profile photo face verification (optional)
# Sign up free at https://www.faceplusplus.com/
# Leave blank → any image is accepted without verification
FACEPP_API_KEY=
FACEPP_API_SECRET=
