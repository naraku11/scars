Options -MultiViews +FollowSymLinks
RewriteEngine On
RewriteBase /

# ── Proxy /api/* and /socket.io/* to Node.js backend (port 3001) ──────────────
<IfModule mod_proxy.c>
  RewriteCond %{REQUEST_URI} ^/api/       [NC,OR]
  RewriteCond %{REQUEST_URI} ^/socket.io/
  RewriteRule ^(.*)$ http://127.0.0.1:3001/$1 [P,L,QSA]
  ProxyPassReverse / http://127.0.0.1:3001/
</IfModule>

# ── SPA routing ───────────────────────────────────────────────────────────────
# Any request that is not a real file or directory is served as index.html
# This allows React Router to handle /dashboard, /officer, /student, etc.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
