# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Hostinger VPS: postgresql://USER:PASSWORD@localhost:5432/scars_db
DATABASE_URL="postgresql://postgres:password@localhost:5432/scars_db"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Long random string — generate with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-string"

# ── Server ───────────────────────────────────────────────────────────────────
# Hostinger sets PORT automatically via environment — leave as 3001 for VPS
PORT=3001
NODE_ENV=production

# ── Face++ API (optional) ────────────────────────────────────────────────────
# Profile photo face-verification. Leave blank to accept any image.
# Get keys at: https://www.faceplusplus.com/
FACEPP_API_KEY=
FACEPP_API_SECRET=
