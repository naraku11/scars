# ── Database ────────────────────────────────────────────────────────────────
# MySQL connection string (Hostinger Business provides MySQL)
# Find credentials in hPanel → Databases → MySQL Databases
# HOST is shown in hPanel — often localhost or a specific hostname
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Long random string — generate with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-string"

# ── Server ───────────────────────────────────────────────────────────────────
# Hostinger sets PORT automatically via environment — leave as 3001 for VPS
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://uv-scars.com

# ── Face++ API (optional) ────────────────────────────────────────────────────
# Profile photo face-verification. Leave blank to accept any image.
# Get keys at: https://www.faceplusplus.com/
FACEPP_API_KEY=
FACEPP_API_SECRET=
